# Database (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# API
PORT=3000
CORS_ORIGIN="http://localhost:4321,http://localhost:4322,http://localhost:4323"
FRONTEND_URL="http://localhost:4321"
IA_API_URL="http://localhost:3001/api"

# Supabase Auth (required by new auth flow)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Session policy
# Keep refresh token cookie for N days when "remember me" is enabled.
REFRESH_TOKEN_COOKIE_DAYS=30
# Set access token JWT lifetime in Supabase Dashboard to daily (86400 seconds):
# Authentication > Settings > JWT expiry limit
